# Copiar este archivo a `.env` y ajustar las URLs según el entorno.
# Solo las variables que empiezan con EXPO_PUBLIC_ llegan al bundle del cliente.
# Después de cambiar .env hay que reiniciar `expo start`.
#
# Dev: el simulador iOS no resuelve "localhost" al Mac — usar la IP del Mac
# en la LAN (la misma que muestra `expo start` en la URL exp://).

EXPO_PUBLIC_API_BASE_DEV=http://192.168.68.106:8090/api
EXPO_PUBLIC_API_BASE_PROD=https://caballoscriollos.com/api
